<%- include('../partials/page-top') %>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card bg-dark border-secondary">
      <div class="card-header border-secondary">
        <h5 class="mb-0 text-white"><i class="fa-solid fa-user-shield me-2 text-info"></i>Atualizar Credenciais</h5>
      </div>
      <div class="card-body">
        <div class="alert alert-info py-2 small mb-3">
          <i class="fa-solid fa-circle-info me-1"></i>Após salvar, sua senha será criptografada com segurança.
        </div>
        <form method="post" action="/account">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label text-secondary">Usuário</label>
            <input type="text" name="username" class="form-control bg-dark-2 text-white border-secondary" value="<%= user ? user.username : '' %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label text-secondary">Nova Senha</label>
            <input type="password" name="password" class="form-control bg-dark-2 text-white border-secondary" required>
          </div>
          <div class="mb-3">
            <label class="form-label text-secondary">Confirmar Senha</label>
            <input type="password" name="confirm_password" class="form-control bg-dark-2 text-white border-secondary" required>
          </div>
          <div class="d-flex justify-content-end">
            <button class="btn btn-info" type="submit" data-submit-btn>
              <i class="fa-solid fa-floppy-disk me-1"></i>Atualizar Credenciais
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/page-bottom') %>

<%- include('../partials/page-top') %>
<div class="row justify-content-center"><div class="col-md-6">
<div class="card bg-dark border-secondary"><div class="card-header border-secondary">
  <h5 class="mb-0 text-white"><i class="fa-solid fa-object-ungroup me-2 text-info"></i>Layout de Anúncios em Frame</h5>
</div><div class="card-body">
<form method="post" action="/ads/frame-layout">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="mb-3"><label class="form-label text-secondary">Layout (0–5)</label>
    <input type="number" name="layout" class="form-control bg-dark-2 text-white border-secondary" value="<%= row.layout %>" min="0" max="5">
  </div>
  <div class="d-flex justify-content-end"><button class="btn btn-info" type="submit" data-submit-btn><i class="fa-solid fa-floppy-disk me-1"></i>Salvar</button></div>
</form>
</div></div>
</div></div>
<%- include('../partials/page-bottom') %>

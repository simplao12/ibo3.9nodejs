<%- include('../partials/page-top') %>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card bg-dark border-secondary">
      <div class="card-header border-secondary">
        <h5 class="mb-0 text-white"><i class="fa-solid fa-plus me-2 text-info"></i>Criar Código de Ativação</h5>
      </div>
      <div class="card-body">
        <form method="post" action="/codes/create">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label text-secondary">Código de Ativação <span class="text-danger">*</span></label>
            <input type="text" name="ac_code" class="form-control bg-dark-2 text-white border-secondary" value="<%= autoCode %>" required>
            <div class="form-text text-muted">Gerado automaticamente. Você pode alterá-lo.</div>
          </div>
          <div class="mb-3">
            <label class="form-label text-secondary">URL do DNS <span class="text-danger">*</span></label>
            <input type="text" name="url" class="form-control bg-dark-2 text-white border-secondary" placeholder="https://exemplo.com" required>
          </div>
          <div class="mb-3">
            <label class="form-label text-secondary">Usuário <span class="text-danger">*</span></label>
            <input type="text" name="username" class="form-control bg-dark-2 text-white border-secondary" required>
          </div>
          <div class="mb-3">
            <label class="form-label text-secondary">Senha <span class="text-danger">*</span></label>
            <input type="text" name="password" class="form-control bg-dark-2 text-white border-secondary" required>
          </div>
          <div class="d-flex gap-2 justify-content-end">
            <a href="/codes" class="btn btn-secondary">Cancelar</a>
            <button class="btn btn-info" type="submit" data-submit-btn>
              <i class="fa-solid fa-floppy-disk me-1"></i>Criar Código
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/page-bottom') %>

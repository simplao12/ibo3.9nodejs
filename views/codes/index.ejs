<%- include('../partials/page-top') %>

<div class="card bg-dark border-secondary">
  <div class="card-header d-flex justify-content-between align-items-center border-secondary">
    <h5 class="mb-0 text-white"><i class="fa-solid fa-key me-2 text-info"></i>Códigos de Ativação</h5>
    <a href="/codes/create" class="btn btn-info btn-sm"><i class="fa-solid fa-plus me-1"></i>Novo Código</a>
  </div>
  <div class="card-body">
    <div class="mb-3">
      <input type="text" id="searchInput" class="form-control bg-dark-2 text-white border-secondary" placeholder="Buscar por código..." value="<%= searchTerm %>">
    </div>
    <% if (codes.length === 0) { %>
      <div class="text-center text-secondary py-4"><i class="fa-solid fa-key fa-2x mb-2 d-block"></i>Nenhum código encontrado.</div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-dark table-hover table-sm">
        <thead><tr><th>Código</th><th>DNS</th><th>Usuário</th><th>Status</th><th class="text-end">Ações</th></tr></thead>
        <tbody>
          <% codes.forEach(function(code) { %>
          <tr>
            <td><code class="text-warning"><%= code.ac_code %></code></td>
            <td><small class="text-muted"><%= code.url %></small></td>
            <td class="text-secondary"><%= code.username %></td>
            <td>
              <% if (code.status === 'USED') { %>
                <span class="badge bg-danger">USADO</span>
              <% } else { %>
                <span class="badge bg-success">Disponível</span>
              <% } %>
            </td>
            <td class="text-end">
              <button class="btn btn-outline-danger btn-sm btn-delete"
                data-delete-url="/codes/<%= code.id %>/delete"
                data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
                <i class="fa-solid fa-trash"></i>
              </button>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <%- include('../partials/pagination', { currentPage: page, totalPages: totalPages, searchTerm: searchTerm }) %>
    <% } %>
  </div>
</div>

<%- include('../partials/confirm-modal') %>
<script>
var t; document.getElementById('searchInput').addEventListener('input', function(e) { clearTimeout(t); t = setTimeout(function() { var p = new URLSearchParams(window.location.search); p.set('search', e.target.value); p.delete('view'); window.location.search = p.toString(); }, 400); });
</script>
<%- include('../partials/page-bottom') %>

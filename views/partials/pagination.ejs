<% if (totalPages > 1) { %>
<nav aria-label="Pagination" class="mt-3">
  <ul class="pagination pagination-sm justify-content-center flex-wrap gap-1">
    <% if (currentPage > 1) { %>
      <li class="page-item">
        <a class="page-link" href="?view=<%= currentPage - 1 %><%= searchTerm ? '&search=' + encodeURIComponent(searchTerm) : '' %>">&laquo; Anterior</a>
      </li>
    <% } %>
    <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= i === currentPage ? 'active' : '' %>">
        <a class="page-link" href="?view=<%= i %><%= searchTerm ? '&search=' + encodeURIComponent(searchTerm) : '' %>"><%= i %></a>
      </li>
    <% } %>
    <% if (currentPage < totalPages) { %>
      <li class="page-item">
        <a class="page-link" href="?view=<%= currentPage + 1 %><%= searchTerm ? '&search=' + encodeURIComponent(searchTerm) : '' %>">Próximo &raquo;</a>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>

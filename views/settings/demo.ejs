<%- include('../partials/page-top') %>
<div class="row justify-content-center"><div class="col-md-8 col-lg-6">
<div class="card bg-dark border-secondary"><div class="card-header border-secondary">
  <h5 class="mb-0 text-white"><i class="fa-solid fa-asterisk me-2 text-info"></i>Playlist Demo</h5>
</div><div class="card-body">
<p class="text-secondary small">Esta playlist é exibida para usuários não registrados.</p>
<form method="post" action="/settings/demo">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="mb-3"><label class="form-label text-secondary">Nome da Playlist</label>
    <input type="text" name="mplname" class="form-control bg-dark-2 text-white border-secondary" value="<%= row.mplname %>"></div>
  <div class="mb-3"><label class="form-label text-secondary">URL do DNS</label>
    <input type="text" name="mdns" class="form-control bg-dark-2 text-white border-secondary" value="<%= row.mdns %>" placeholder="https://exemplo.com"></div>
  <div class="mb-3"><label class="form-label text-secondary">Usuário</label>
    <input type="text" name="muser" class="form-control bg-dark-2 text-white border-secondary" value="<%= row.muser %>"></div>
  <div class="mb-3"><label class="form-label text-secondary">Senha</label>
    <input type="text" name="mpass" class="form-control bg-dark-2 text-white border-secondary" value="<%= row.mpass %>"></div>
  <div class="d-flex justify-content-end"><button class="btn btn-info" type="submit" data-submit-btn><i class="fa-solid fa-floppy-disk me-1"></i>Salvar</button></div>
</form>
</div></div>
</div></div>
<%- include('../partials/page-bottom') %>

<%- include('../partials/page-top') %>
<div class="row justify-content-center"><div class="col-md-8 col-lg-6">
<div class="card bg-dark border-secondary"><div class="card-header border-secondary">
  <h5 class="mb-0 text-white"><i class="fa-solid fa-font me-2 text-info"></i>Texto da Página de Login</h5>
</div><div class="card-body">
<form method="post" action="/settings/login-text">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="mb-3"><label class="form-label text-secondary">Título de Login</label>
    <input type="text" name="logintitial" class="form-control bg-dark-2 text-white border-secondary" value="<%= row.logintitial %>"></div>
  <div class="mb-3"><label class="form-label text-secondary">Subtítulo de Login</label>
    <input type="text" name="loginsubtitial" class="form-control bg-dark-2 text-white border-secondary" value="<%= row.loginsubtitial %>"></div>
  <div class="d-flex justify-content-end"><button class="btn btn-info" type="submit" data-submit-btn><i class="fa-solid fa-floppy-disk me-1"></i>Salvar</button></div>
</form>
</div></div>
</div></div>
<%- include('../partials/page-bottom') %>

<%- include('../partials/page-top') %>
<div class="row justify-content-center"><div class="col-md-8 col-lg-6">
<div class="card bg-dark border-secondary"><div class="card-header border-secondary">
  <h5 class="mb-0 text-white"><i class="fa-solid fa-comment-dots me-2 text-info"></i>Definir Notificação</h5>
</div><div class="card-body">
<form method="post" action="/settings/notification">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="mb-3"><label class="form-label text-secondary">Título da Notificação</label>
    <input type="text" name="message_one" class="form-control bg-dark-2 text-white border-secondary" value="<%= row.message_one %>"></div>
  <div class="mb-3"><label class="form-label text-secondary">Conteúdo da Notificação</label>
    <textarea name="message_two" class="form-control bg-dark-2 text-white border-secondary" rows="3"><%= row.message_two %></textarea></div>
  <div class="d-flex justify-content-end"><button class="btn btn-info" type="submit" data-submit-btn><i class="fa-solid fa-floppy-disk me-1"></i>Salvar</button></div>
</form>
</div></div>
</div></div>
<%- include('../partials/page-bottom') %>

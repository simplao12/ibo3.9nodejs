<%- include('../partials/page-top') %>

<div class="card bg-dark border-secondary">
  <div class="card-header border-secondary">
    <h5 class="mb-0 text-white"><i class="fa-solid fa-palette me-2 text-info"></i>Temas do App</h5>
  </div>
  <div class="card-body">
    <p class="text-secondary small mb-3">Tema atual: <strong class="text-info"><%= currentTheme %></strong></p>
    <form method="post" action="/themes">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="row g-3">
        <% themes.forEach(function(theme) { %>
        <div class="col-6 col-md-4 col-lg-3 col-xl-2">
          <div class="theme-card <%= currentTheme === theme ? 'theme-active' : '' %>" onclick="selectTheme('<%= theme %>')">
            <img src="/img/theme/<%= theme %>_resized.png" alt="<%= theme %>" class="img-fluid rounded"
              onerror="this.src='/img/theme/placeholder.png'; this.onerror=null;">
            <div class="theme-label"><%= theme %></div>
          </div>
        </div>
        <% }); %>
      </div>
      <input type="hidden" name="theme_no" id="selectedTheme" value="<%= currentTheme %>">
      <div class="mt-4 d-flex justify-content-end">
        <button class="btn btn-info" type="submit" data-submit-btn>
          <i class="fa-solid fa-floppy-disk me-1"></i>Aplicar Tema
        </button>
      </div>
    </form>
  </div>
</div>

<script>
function selectTheme(name) {
  document.querySelectorAll('.theme-card').forEach(function(c) { c.classList.remove('theme-active'); });
  event.currentTarget.classList.add('theme-active');
  document.getElementById('selectedTheme').value = name;
}
</script>
<%- include('../partials/page-bottom') %>

<%- include('../partials/page-top') %>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card bg-dark border-secondary">
      <div class="card-header border-secondary">
        <h5 class="mb-0 text-white"><i class="fa-solid fa-pen me-2 text-info"></i>Editar Expiração</h5>
      </div>
      <div class="card-body">
        <form method="post" action="/trial/<%= row.id %>/edit">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label text-secondary">Endereço MAC</label>
            <input type="text" class="form-control bg-dark-2 text-secondary border-secondary" value="<%= row.mac_address %>" disabled>
          </div>
          <div class="mb-3">
            <label class="form-label text-secondary">Data de Expiração</label>
            <input type="date" name="expire_date" class="form-control bg-dark-2 text-white border-secondary" value="<%= row.expire_date %>" required>
          </div>
          <div class="d-flex gap-2 justify-content-end">
            <a href="/trial" class="btn btn-secondary">Cancelar</a>
            <button class="btn btn-info" type="submit" data-submit-btn><i class="fa-solid fa-floppy-disk me-1"></i>Atualizar</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/page-bottom') %>

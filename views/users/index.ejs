<%- include('../partials/page-top') %>

<div class="card bg-dark border-secondary">
  <div class="card-header d-flex justify-content-between align-items-center border-secondary">
    <h5 class="mb-0 text-white"><i class="fa-solid fa-users me-2 text-info"></i>Usuários MAC</h5>
    <a href="/users/create" class="btn btn-info btn-sm">
      <i class="fa-solid fa-plus me-1"></i>Novo Usuário
    </a>
  </div>
  <div class="card-body">
    <!-- Busca com debounce -->
    <div class="mb-3">
      <input type="text" id="searchInput" class="form-control bg-dark-2 text-white border-secondary"
        placeholder="Buscar por MAC ou título..." value="<%= searchTerm %>">
    </div>

    <% if (users.length === 0) { %>
      <div class="text-center text-secondary py-4">
        <i class="fa-solid fa-magnifying-glass fa-2x mb-2 d-block"></i>
        Nenhum usuário encontrado. <% if (!searchTerm) { %><a href="/users/create" class="text-info">Adicione um</a>.<% } %>
      </div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-dark table-hover table-sm">
        <thead>
          <tr>
            <th>Título</th>
            <th>Endereço MAC</th>
            <th>Usuário</th>
            <th>Protegido</th>
            <th>DNS</th>
            <th class="text-end">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(user) { %>
          <tr>
            <td class="text-white fw-semibold"><%= user.title %></td>
            <td><code class="text-warning"><%= user.mac_address %></code></td>
            <td class="text-secondary"><%= user.username %></td>
            <td>
              <% if (user.protection === '1') { %>
                <span class="badge bg-success">SIM</span>
              <% } else { %>
                <span class="badge bg-secondary">NÃO</span>
              <% } %>
            </td>
            <td><small class="text-muted"><%= user.url %></small></td>
            <td class="text-end">
              <a href="/users/<%= user.id %>/edit" class="btn btn-outline-info btn-sm" title="Editar">
                <i class="fa-solid fa-pen"></i>
              </a>
              <a href="/trial/create?mac=<%= encodeURIComponent(user.mac_address) %>" class="btn btn-outline-warning btn-sm" title="Definir Expiração">
                <i class="fa-solid fa-calendar-days"></i>
              </a>
              <button class="btn btn-outline-danger btn-sm btn-delete"
                data-delete-url="/users/<%= user.id %>/delete"
                data-bs-toggle="modal" data-bs-target="#confirmDeleteModal" title="Excluir">
                <i class="fa-solid fa-trash"></i>
              </button>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <%- include('../partials/pagination', { currentPage: page, totalPages: totalPages, searchTerm: searchTerm }) %>
    <% } %>
  </div>
</div>

<%- include('../partials/confirm-modal') %>

<script>
var searchTimeout;
document.getElementById('searchInput').addEventListener('input', function(e) {
  clearTimeout(searchTimeout);
  searchTimeout = setTimeout(function() {
    var params = new URLSearchParams(window.location.search);
    params.set('search', e.target.value);
    params.delete('view');
    window.location.search = params.toString();
  }, 400);
});
</script>

<%- include('../partials/page-bottom') %>
